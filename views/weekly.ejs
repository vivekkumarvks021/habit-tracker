<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link rel="stylesheet" href="/css/common.css">
    <link rel="stylesheet" href="/css/weekly.css">

    <title><%= habit.name %></title>
</head>

<body>

    <main class="container">

        <!-- Page Header -->
        <header class="page-header">

            <a
                class="back-btn"
                href="/"
            >
                ← Back
            </a>

            <h1 class="page-title">
                <%= habit.name %>
            </h1>

            <p class="section-subtitle">
                Last 7 Days
            </p>

        </header>

        <!-- Notification container -->
        <%- include("partials/notification") %>

        <!-- Weekly habit tracking list -->
        <section class="weekly-list">

            <!-- Render the last 7 days -->
            <% weekData.forEach((day) => { %>

                <article class="day-card">

                    <div class="day-details">

                        <h3 class="day-name">
                            <%= day.day %>
                        </h3>

                        <p class="day-date">
                            <%= day.date %>
                        </p>

                    </div>

                    <!-- Status button for the selected day -->
                    <button
                        class="status-btn status-<%= day.status %> <%= day.isDisabled ? 'status-disabled' : '' %>"
                        data-date="<%= day.fullDate %>"
                        data-status="<%= day.status %>"
                        data-original-status="<%= day.status %>"
                        <%= day.isDisabled ? "disabled" : "" %>
                    >

                        <!-- Display status icon -->
                        <% if (day.status === "done") { %>
                            ✅
                        <% } else if (day.status === "not-done") { %>
                            ❌
                        <% } else { %>
                            ⚪
                        <% } %>

                    </button>

                </article>

            <% }) %>

        </section>

        <!-- Save updated habit statuses -->
        <footer class="page-footer">

            <button
                id="save-btn"
                class="btn btn-primary"
                disabled
            >
                Save Changes
            </button>

        </footer>

    </main>

    <script src="/js/common.js"></script>
    <script src="/js/weekly.js"></script>

</body>

</html>